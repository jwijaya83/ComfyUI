# Trim the build context (the ComfyUI dir is ~70 GB). Keep venv/ and the persona LoRAs
# (models/loras/*.safetensors are baked in). The base checkpoint, text encoder, and the
# dynamic distilled LoRA come from RunPod's HF model cache at boot (fetch_models.py),
# so exclude them from the image.
.git
SageAttention
**/__pycache__
**/*.pyc
# Local handler venv used to test the handler/gcs upload off-RunPod (mirrors the
# container's /opt/handler-venv). Never bake it — the image builds its own. Does NOT
# match the root venv/ (the prebuilt ComfyUI venv), which is kept intentionally.
**/.venv/
tests
tests-unit
*.log

# Foundation models — pulled from the HF cache at runtime, NOT baked (~40 GB saved).
models/checkpoints
# https://huggingface.co/Lightricks/LTX-2.3-fp8/blob/main/ltx-2.3-22b-dev-fp8.safetensors
models/text_encoders
# https://huggingface.co/Comfy-Org/ltx-2/blob/main/split_files/text_encoders/gemma_3_12B_it_fp8_scaled.safetensors

# LTX distilled LoRAs. Persona LoRAs in models/loras/ stay baked; the ltx23 ones are
# externalized. The DYNAMIC LoRA (used by the per-turn basic/latent_injection path) is
# fetched from HF at boot (fetch_models.py); excluded here, ~2.6 GB saved.
models/loras/ltx-2.3-22b-distilled-lora-dynamic_fro09_avg_rank_105_bf16.safetensors
# https://huggingface.co/Kijai/LTX2.3_comfy/blob/main/loras/ltx-2.3-22b-distilled-lora-dynamic_fro09_avg_rank_105_bf16.safetensors

